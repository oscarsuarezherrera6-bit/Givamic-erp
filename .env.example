# ============================================================
# GIVAMIC ERP — Variables de entorno para Supabase
# ============================================================
# 1. Crea un proyecto en https://supabase.com
# 2. Ve a Settings → API
# 3. Copia la "Project URL" y la "anon public" key
# 4. Pega los valores abajo y renombra este archivo a .env
#    (o agrégalas en Vercel: Settings → Environment Variables)
# ============================================================

# URL del proyecto Supabase (ej: https://abcdef.supabase.co)
VITE_SUPABASE_URL=

# Clave pública anon (es segura para el frontend — la protección viene de RLS)
VITE_SUPABASE_ANON_KEY=

# ── Sin estas variables el sistema funciona en modo localStorage (sin cambios) ──
